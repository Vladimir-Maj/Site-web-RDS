{% extends "base.html.twig" %}

{% block body %}
<main class="container">
    <div class="page-header" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
        <h1>Mon compte</h1>
        <a href="logout.php" class="btn btn-outline">Déconnexion</a>
    </div>

    <div class="profile-layout" style="display: flex; gap: 2rem;">
        {# Colonne latérale #}
        <aside style="flex: 1;">
            <div class="card" style="text-align: center; padding: 2rem;">
                <div class="avatar" style="width: 80px; height: 80px; background: var(--primary-color, #007bff); color: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 2rem; margin: 0 auto 1rem;">
                    {{ user.username|slice(0, 1)|upper }}
                </div>
                <h3 style="margin-bottom: 0.5rem;">{{ user.username }}</h3>
                <p style="color: #666; margin-bottom: 1rem;">{{ user.email }}</p>
                <span class="tag" style="background: #eee; padding: 0.2rem 0.8rem; border-radius: 12px; font-size: 0.8rem;">
                    {{ user.role|capitalize }}
                </span>
            </div>
        </aside>

        {# Section principale #}
        <section style="flex: 2;">
            <div class="card" style="padding: 2rem;">
                <h2 style="margin-bottom: 1.5rem;">Informations personnelles</h2>
                <p><strong>Membre depuis :</strong> {{ user.created_at|date('d/m/Y') }}</p>
                
                <hr style="margin: 2rem 0; border: 0; border-top: 1px solid #eee;">
                
                <h2 style="margin-bottom: 1.5rem;">CV / Documents</h2>
                {% if user.cv_path %}
                    <div style="display: flex; gap: 1rem; align-items: center;">
                        <a href="{{ user.cv_path }}" class="btn btn-primary" target="_blank">Voir mon CV actuel</a>
                        <a href="upload_cv.php" class="btn btn-ghost">Modifier le fichier</a>
                    </div>
                {% else %}
                    <p style="margin-bottom: 1rem; color: #666;">Aucun CV enregistré pour le moment.</p>
                    <a href="upload_cv.php" class="btn btn-primary">Ajouter mon CV</a>
                {% endif %}
            </div>
        </section>
    </div>
</main>
{% endblock %}