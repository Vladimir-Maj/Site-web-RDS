{# views/sites/index.html.twig #}
{% extends "base.html.twig" %}

{% block title %}Sites de {{ company.name }} — StageFlow{% endblock %}

{% block body %}
    <div class="page-header">
        <div>
            <h1>Sites de l'entreprise</h1>
            <p>Gestion des adresses et SIRET pour <strong>{{ company.name }}</strong></p>
        </div>
        <div style="display: flex; gap: 10px;">
            <a href="/app/companies/{{ company.id }}" class="btn btn-ghost">← Retour Société</a>
            <a href="/app/sites/new?company_id={{ company.id }}" class="btn btn-primary">+ Ajouter un site</a>
        </div>
    </div>

    {# --- Notice : Style Catalogue --- #}
    <div class="notice notice-info">
        <div class="notice-icon">📍</div>
        <p>
            {% if sites is empty %}
                Aucun site n'est encore enregistré pour cette entreprise. Les sites permettent de localiser précisément les offres de stage.
            {% else %}
                Il y a actuellement <strong>{{ sites|length }} site{{ sites|length > 1 ? 's' : '' }}</strong> enregistré{{ sites|length > 1 ? 's' : '' }} pour cette organisation.
            {% endif %}
        </p>
    </div>

    {# --- Liste des sites (Tableau) --- #}
    {% if sites is not empty %}
        <div class="card p-0 overflow-hidden" style="margin-top: 1rem;">
            <div class="table-responsive">
                <table class="table">
                    <thead>
                        <tr>
                            <th>Ville</th>
                            <th>Adresse</th>
                            <th>SIRET</th>
                            <th class="text-right">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for site in sites %}
                            <tr>
                                <td>
                                    <strong>{{ site.city|default('N/A') }}</strong>
                                </td>
                                <td class="text-sm">
                                    {{ site.address|default('-')|nl2br }}
                                </td>
                                <td>
                                    {% if site.tax_id %}
                                        <code class="text-xs" style="background: var(--bg-alt); padding: 2px 5px; border-radius: 4px;">
                                            {{ site.tax_id }}
                                        </code>
                                    {% else %}
                                        <span class="text-muted text-xs">Non renseigné</span>
                                    {% endif %}
                                </td>
                                <td class="text-right">
                                    <div style="display: flex; justify-content: flex-end; gap: 8px;">
                                        <a href="/app/sites/{{ site.id }}?company_id={{ company.id }}" class="btn btn-ghost btn-sm">Modifier</a>
                                        
                                        <form action="/app/sites/delete/{{ site.id }}" method="POST" onsubmit="return confirm('Supprimer ce site ?');" style="margin:0;">
                                            <input type="hidden" name="company_id" value="{{ company.id }}">
                                            <button type="submit" class="btn btn-danger btn-sm">Supprimer</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    {% endif %}
{% endblock %}