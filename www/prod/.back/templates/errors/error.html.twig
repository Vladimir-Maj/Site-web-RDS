{% extends 'base.html.twig' %}

{% block title %}Erreur - {{ error_code|default('Erreur') }}{% endblock %}

{% block body %}
<div class="error-page">
    <h1>Erreur {{ error_code|default('500') }}</h1>
    <p>{{ error_message|default('Une erreur inattendue s\'est produite.') }}</p>
    <a href="/" class="btn">Retour à l'accueil</a>
</div>
{% endblock %}
