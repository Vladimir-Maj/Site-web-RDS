{% extends "base.html.twig" %}

{% block body %}
    <main class="container">
        <div class="auth-container" style="max-width: 500px; margin: 2rem auto;">
            <h1 style="text-align: center; margin-bottom: 2rem;">Créer un compte</h1>

            {% if error %}
                <div class="alert alert-error" style="background: #f8d7da; color: #721c24; padding: 1rem; border-radius: 4px; margin-bottom: 1.5rem;">
                    {{ error }}
                </div>
            {% endif %}

            {% if success %}
                <div class="alert alert-success" style="background: #d4edda; color: #155724; padding: 1rem; border-radius: 4px; margin-bottom: 1.5rem;">
                    {{ success }}
                    <div style="margin-top: 0.5rem;">
                        <a href="/login" class="btn btn-primary">Se connecter</a>
                    </div>
                </div>
            {% endif %}

            {% if not success %}
                <section class="card" style="padding: 2rem;">
                    {# Updated action to match route #}
                    <form method="POST" action="/register">
                        {# TASK-28: CSRF Token #}
                        <input type="hidden" name="csrf_token" value="{{ csrf_token }}">

                        <div class="form-group">
                            <label for="username">Nom d'utilisateur</label>
                            <input type="text" id="username" name="username" value="{{ old.username|default('') }}" required placeholder="ex: jdoe54">
                        </div>

                        <div class="form-group">
                            <label for="email">Email</label>
                            <input type="email" id="email" name="email" value="{{ old.email|default('') }}" required placeholder="ex: jean.dupont@email.com">
                        </div>

                        <div class="form-group">
                            <label for="role">Je suis un :</label>
                            <select id="role" name="role">
                                <option value="student" {{ old.role|default('') == 'student' ? 'selected' : '' }}>Étudiant</option>
                                <option value="pilote" {{ old.role|default('') == 'pilote' ? 'selected' : '' }}>Pilote</option>
                            </select>
                        </div>

                        <div class="form-group">
                            <label for="password">Mot de passe</label>
                            <input type="password" id="password" name="password" required minlength="8">
                        </div>

                        <div class="form-group">
                            <label for="confirm_password">Confirmer le mot de passe</label>
                            <input type="password" id="confirm_password" name="confirm_password" required minlength="8">
                        </div>

                        <button type="submit" class="btn btn-primary" style="width: 100%; margin-top: 1rem;">
                            S'inscrire
                        </button>
                    </form>

                    <div class="form-footer" style="margin-top: 1.5rem; text-align: center;">
                        Déjà un compte ? <a href="/login">Connectez-vous ici</a>.
                    </div>
                </section>
            {% endif %}
        </div>
    </main>
{% endblock %}