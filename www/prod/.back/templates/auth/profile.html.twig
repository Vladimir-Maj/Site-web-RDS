{% extends "base.html.twig" %}
{% block body %}
<main class="container">
    <div class="page-header" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
        <h1>Mon compte</h1>
        <a href="/logout" class="btn btn-outline">Déconnexion</a>
    </div>

    <div class="profile-layout" style="display: flex; gap: 2rem;">

        <aside style="flex: 1;">
            <div class="card" style="text-align: center; padding: 2rem;">
                <div class="avatar" style="width: 80px; height: 80px; background: #6366f1; color: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 2rem; margin: 0 auto 1rem;">
                    {{ (user.first_name_user|default(user.email_user))|slice(0, 1)|upper }}
                </div>
                <h3 style="margin-bottom: 0.5rem;">{{ user.first_name_user }} {{ user.last_name_user }}</h3>
                <p style="color: #666; margin-bottom: 1rem;">{{ user.email_user }}</p>
                <span class="tag" style="background: #e0e7ff; color: #4338ca; padding: 0.2rem 0.8rem; border-radius: 12px; font-size: 0.8rem; font-weight: bold;">
                    {{ user.role.value|upper }}
                </span>
            </div>
        </aside>

        <section style="flex: 2;">
            <div class="card" style="padding: 2rem;">
                <h2 style="margin-bottom: 1.5rem;">Informations personnelles</h2>
                <p>
                    <strong>Membre depuis :</strong>
                    {{ user.created_at_user ? user.created_at_user|date('d/m/Y') : 'Non renseigné' }}
                </p>
            </div>
        </section>

    </div>
</main>
{% endblock %}
