{# .back/views/offers/offer_search.html.twig #}
{% extends "dashboard/layout.html.twig" %}

{% block title %}Rechercher une offre — StageFlow{% endblock %}

{% block dashboard_content %}
    <div class="page-header">
        <div>
            <h1>Trouver votre opportunité</h1>
            <p>Utilisez les filtres pour explorer le catalogue des stages.</p>
        </div>
    </div>

    {# --- Filter Section --- #}
    <section class="card search-bar" style="display: block; width: 100%; padding: 1.5rem; margin-bottom: 2rem;">
        <form method="GET" action="/app/offers/search">
            <div class="form-grid">
                
                <div class="form-group">
                    <label for="keyword">Recherche libre</label>
                    <input type="text" name="keyword" id="keyword" placeholder="Poste, technologies..." value="{{ filters.keyword|default('') }}">
                </div>

                <div class="form-group">
                    <label for="city">Ville / Localisation</label>
                    <input type="text" name="city" id="city" placeholder="ex: Nancy" value="{{ filters.city|default('') }}">
                </div>

                <div class="form-group">
                    <label for="duration">Durée max (semaines)</label>
                    <input type="number" name="duration" id="duration" placeholder="ex: 16" value="{{ filters.duration|default('') }}">
                </div>

                <div class="form-group" style="display: flex; align-items: flex-end;">
                    <button type="submit" class="btn btn-primary" style="width: 100%;">🔍 Lancer la recherche</button>
                </div>
            </div>
            
            <div style="margin-top: 1.2rem; display: flex; justify-content: space-between; align-items: center;">
                <a href="/app/offers/search" class="text-sm text-muted">✕ Réinitialiser les filtres</a>
                
                {# Sorting select #}
                <div class="sort-select">
                    <label class="text-sm" style="margin-right: 8px;">Trier par :</label>
                    <select name="sort" onchange="this.form.submit()" style="width: auto; padding: 2px 10px;">
                        <option value="recent" {{ filters.sort == 'recent' ? 'selected' : '' }}>Plus récentes</option>
                        <option value="rate" {{ filters.sort == 'rate' ? 'selected' : '' }}>Gratification</option>
                        <option value="duration" {{ filters.sort == 'duration' ? 'selected' : '' }}>Durée</option>
                    </select>
                </div>
            </div>
        </form>
    </section>

    {# --- Results Counter --- #}
    <div class="notice notice-info">
        <div class="notice-icon">📊</div>
        <p><strong>{{ count }}</strong> offre{{ count > 1 ? 's' : '' }} trouvée{{ count > 1 ? 's' : '' }} pour votre sélection.</p>
    </div>

    {# --- Results Grid --- #}
    <div class="offer-list">
        {% for offer in offers %}
            {{ include('components/card_template.twig', {'offer': offer}) }}
        {% else %}
            <div class="card" style="text-align: center; padding: 5rem 2rem;">
                <div style="font-size: 2rem; margin-bottom: 1rem;">📭</div>
                <h3 class="text-muted">Aucun résultat trouvé</h3>
                <p class="text-sm">Essayez de simplifier vos mots-clés ou d'élargir la zone géographique.</p>
                <a href="/app/offers/search" class="btn btn-ghost mt-2">Voir toutes les offres</a>
            </div>
        {% endfor %}
    </div>

    {# --- Pagination --- #}
    {% if totalPages > 1 %}
        <div class="pagination" style="display: flex; justify-content: center; gap: 10px; margin-top: 3rem;">
            {% for i in 1..totalPages %}
                <a href="?page={{ i }}&keyword={{ filters.keyword|url_encode }}&city={{ filters.city|url_encode }}&duration={{ filters.duration|default('') }}&sort={{ filters.sort|default('recent') }}" 
                   class="btn {{ page == i ? 'btn-primary' : 'btn-ghost' }}">
                    {{ i }}
                </a>
            {% endfor %}
        </div>
    {% endif %}
{% endblock %}