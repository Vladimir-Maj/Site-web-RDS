{#
================================================================================
  apply.html.twig ? Student Job Application Form
================================================================================

PURPOSE:
  Allows students to submit applications to job offers with CV and motivation
  letter uploads. Supports both selecting existing files and uploading new ones.

FEATURE: SFx20 - Student Application Submission
ACCESS: Students only (authenticated)
ROUTE: GET /app/offers/{id}/apply | POST /app/offers/{id}/apply

================================================================================
#}

{% extends "base.html.twig" %}

{% block title %}Postuler ? {{ offer.title }} ? StageFlow{% endblock %}

{% block body %}

	{# --- PAGE HEADER --- #}
	<div class="page-header">
		<div>
			<a href="/app/offers/show/{{ offer.id }}" class="btn btn-ghost" style="border: none; padding-left: 0;">
				? Retour � l'offre
			</a>
			<h1 class="mt-1">Postuler � cette offre</h1>
			<p>
				{{ offer.title }}
				?
				<strong>{{ offer.company_name }}</strong>
				�
				{{ offer.location }}
			</p>
		</div>
	</div>

	{# --- ERROR NOTIFICATION --- #}
	{% if error %}
		<div class="notice notice-error mb-2">
			<div class="notice-icon">??</div>
			<p><strong>Erreur :</strong> {{ error }}</p>
		</div>
	{% endif %}

	<div class="profile-layout">
		{# --- SIDEBAR (OFFER & CANDIDATE INFO) --- #}
		<aside>
			{# Offer Summary #}
			<div class="card user-card">
				<div class="avatar-circle">?</div>
				<h3>{{ offer.company_name }}</h3>
				<p class="text-sm text-muted">{{ offer.location }}</p>

				<div class="data-grid mt-3" style="text-align: left;">
					<div class="data-item">
						<span class="data-label">Poste</span>
						<span class="data-value">{{ offer.title }}</span>
					</div>
					<div class="data-item">
						<span class="data-label">Gratification</span>
						<span class="data-value">{{ offer.hourly_rate|default('N/C') }} ?/h</span>
					</div>
					<div class="data-item">
						<span class="data-label">Dur�e</span>
						<span class="data-value">{{ offer.duration_weeks|default('?') }} semaines</span>
					</div>
				</div>
			</div>

			{# Candidate Summary #}
			<div class="card mt-2" style="padding: 1.25rem;">
				<p class="text-sm" style="text-transform: uppercase; letter-spacing: 1px; color: var(--primary-color); margin-bottom: 0.75rem;">
					Candidat
				</p>

				<div class="data-grid">
					<div class="data-item">
						<span class="data-label">Pr�nom</span>
						<span class="data-value">{{ currentUser.first_name|default(user.first_name|default('')) }}</span>
					</div>
					<div class="data-item">
						<span class="data-label">Email</span>
						<span class="data-value" style="word-break: break-all;">
                            {{ currentUser.email|default(user.email|default('')) }}
                        </span>
					</div>
				</div>

				<a href="/profile" class="text-sm text-muted" style="display: inline-block; margin-top: 0.75rem;">
					?? Modifier mon profil
				</a>
			</div>

			{# Offer Stats #}
			<div class="card mt-2" style="padding: 1.25rem; background-color: rgba(var(--primary-rgb), 0.03);">
				<p class="text-sm" style="text-transform: uppercase; letter-spacing: 1px; color: var(--primary-color); margin-bottom: 0.75rem;">
					Statistiques de l'offre
				</p>

				<div class="data-grid">
					<div class="data-item">
						<span class="data-label">?? Vues</span>
						<span class="data-value">{{ views|default(0) }}</span>
					</div>
					<div class="data-item">
						<span class="data-label">? Candidatures</span>
						<span class="data-value">{{ applications|default(0) }}</span>
					</div>
				</div>

				{% if applications|default(0) > 10 %}
					<p class="text-xs text-muted mt-2">? Offre tr�s demand�e !</p>
				{% endif %}
			</div>
		</aside>

		{# --- MAIN FORM SECTION --- #}
		<section>
			<form id="applyForm" action="/app/offers/{{ offer.id }}/apply" method="POST" enctype="multipart/form-data">
				<input type="hidden" name="csrf_token" value="{{ csrf_token }}">

				{# SECTION 1: CV #}
				<div class="form-section-header" style="margin-bottom: 1.5rem; border-bottom: 1px solid var(--border-color); padding-bottom: 0.5rem;">
					<h3 class="text-sm" style="text-transform: uppercase; letter-spacing: 1px; color: var(--primary-color);">
						01. Curriculum Vit�
					</h3>
				</div>

				<div class="form-group mb-3">
					<label for="cv_id">Choisir un CV d�j� utilis�</label>
					<select name="cv_path" id="cv_id">
						<option value="" selected>? Chargement de vos CVs? ?</option>
					</select>
				</div>

				<p class="text-sm text-muted" style="text-align: center; margin: 1rem 0;">
					? ou d�posez un nouveau fichier ?
				</p>

				<div class="form-group mb-3">
					<label id="cv-drop-zone" class="file-dropzone">
						<span id="cv-drop-icon" class="file-dropzone-icon">?</span>
						<p id="cv-drop-label" class="file-dropzone-title">D�posez votre CV ici</p>
						<p class="file-dropzone-subtitle">ou cliquez pour parcourir (PDF max 2 Mo)</p>
						<input type="file" name="cv_file" id="cv_file_input" accept=".pdf" class="file-input-hidden">
					</label>
				</div>

				{# SECTION 2: Motivation Letter #}
				<div class="form-section-header" style="margin-bottom: 1.5rem; border-bottom: 1px solid var(--border-color); padding-bottom: 0.5rem; margin-top: 2rem;">
					<h3 class="text-sm" style="text-transform: uppercase; letter-spacing: 1px; color: var(--primary-color);">
						02. Lettre de motivation
					</h3>
				</div>

				<div class="form-group mb-3">
					<label for="motivation_id">Choisir une lettre existante</label>
					<select name="cover_letter_path" id="motivation_id">
						<option value="" selected>? Chargement de vos lettres? ?</option>
					</select>
				</div>

				<p class="text-sm text-muted" style="text-align: center; margin: 1rem 0;">
					? ou d�posez un nouveau fichier ?
				</p>

				<div class="form-group mb-3">
					<label id="motivation-drop-zone" class="file-dropzone">
						<span id="motivation-drop-icon" class="file-dropzone-icon">?</span>
						<p id="motivation-drop-label" class="file-dropzone-title">D�posez votre lettre ici</p>
						<p class="file-dropzone-subtitle">ou cliquez pour parcourir (PDF max 2 Mo)</p>
						<input type="file" name="cover_letter_file" id="motivation_file_input" accept=".pdf" class="file-input-hidden">
					</label>
				</div>

				{# FORM ACTIONS #}
				<div style="margin-top: 2.5rem; padding-top: 1.5rem; border-top: 1px dashed var(--border-color); display: flex; justify-content: space-between; align-items: center;">
					<a href="/app/offers/show/{{ offer.id }}" class="text-sm text-muted">? Annuler</a>
					<button type="submit" class="btn btn-primary" id="submitBtn">? Envoyer ma candidature</button>
				</div>
			</form>
		</section>
	</div>

	{# --- JAVASCRIPT LOGIC --- #}
	<script>
		document.addEventListener('DOMContentLoaded', function () {
			const form      = document.getElementById('applyForm');
			const submitBtn = document.getElementById('submitBtn');

			const cvSelect   = document.getElementById('cv_id');
			const cvDropZone = document.getElementById('cv-drop-zone');
			const cvInput    = document.getElementById('cv_file_input');
			const cvLabel    = document.getElementById('cv-drop-label');
			const cvIcon     = document.getElementById('cv-drop-icon');

			const lmSelect   = document.getElementById('motivation_id');
			const lmDropZone = document.getElementById('motivation-drop-zone');
			const lmInput    = document.getElementById('motivation_file_input');
			const lmLabel    = document.getElementById('motivation-drop-label');
			const lmIcon     = document.getElementById('motivation-drop-icon');

			const validatePDF = (file) => {
				if (!file) return false;

				const isPDF = file.type === 'application/pdf' ||
						(file.name && file.name.toLowerCase().endsWith('.pdf'));

				if (!isPDF) {
					alert('Seuls les fichiers PDF sont accept�s.');
					return false;
				}

				if (file.size > 2 * 1024 * 1024) {
					alert('Le fichier d�passe la limite de 2 Mo.');
					return false;
				}

				return true;
			};

			const resetDropZone = (icon, label, zone, defaultText) => {
				icon.textContent = '?';
				label.textContent = defaultText;
				zone.classList.remove('active');
			};

			const setDropZoneSuccess = (icon, label, zone, fileName) => {
				icon.textContent = '?';
				label.textContent = fileName;
				zone.classList.add('active');
			};

			async function loadExistingFiles(endpoint, selectEl, placeholderText) {
				try {
					const res = await fetch(endpoint, {
						headers: { 'X-Requested-With': 'XMLHttpRequest' }
					});

					if (!res.ok) throw new Error('HTTP ' + res.status);

					const files = await res.json();
					selectEl.innerHTML = '';

					if (!files || files.length === 0) {
						selectEl.innerHTML = '<option value="" disabled selected>? Aucun fichier enregistr� ?</option>';
						return;
					}

					const placeholder = document.createElement('option');
					placeholder.value = '';
					placeholder.selected = true;
					placeholder.textContent = placeholderText;
					selectEl.appendChild(placeholder);

					files.forEach(item => {
						const filePath = item.file_path || item.path || '';
						if (!filePath) return;

						const opt = document.createElement('option');
						opt.value = filePath;
						opt.textContent = filePath.split('/').pop();
						selectEl.appendChild(opt);
					});
				} catch (error) {
					selectEl.innerHTML = '<option value="" disabled selected>? Erreur de chargement ?</option>';
				}
			}

			function bindDropZone(dropZone, input, select, icon, label, defaultText) {
				input.addEventListener('change', (e) => {
					const file = e.target.files[0];
					if (!validatePDF(file)) {
						input.value = '';
						resetDropZone(icon, label, dropZone, defaultText);
						return;
					}
					select.value = '';
					setDropZoneSuccess(icon, label, dropZone, file.name);
				});

				select.addEventListener('change', () => {
					if (select.value !== '') {
						input.value = '';
						resetDropZone(icon, label, dropZone, defaultText);
					}
				});

				dropZone.addEventListener('dragover', (e) => {
					e.preventDefault();
					dropZone.classList.add('active');
				});

				dropZone.addEventListener('dragleave', (e) => {
					e.preventDefault();
					if (input.files.length === 0) {
						resetDropZone(icon, label, dropZone, defaultText);
					}
				});

				dropZone.addEventListener('drop', (e) => {
					e.preventDefault();
					if (!e.dataTransfer || e.dataTransfer.files.length === 0) return;

					const file = e.dataTransfer.files[0];
					if (!validatePDF(file)) return;

					input.files = e.dataTransfer.files;
					select.value = '';
					setDropZoneSuccess(icon, label, dropZone, file.name);
				});
			}

			// Initialization
			loadExistingFiles('/api/profile/get-cvs', cvSelect, '? S�lectionner un CV ?');
			loadExistingFiles('/api/profile/get-lms', lmSelect, '? S�lectionner une lettre ?');

			bindDropZone(cvDropZone, cvInput, cvSelect, cvIcon, cvLabel, 'D�posez votre CV ici');
			bindDropZone(lmDropZone, lmInput, lmSelect, lmIcon, lmLabel, 'D�posez votre lettre ici');

			form.addEventListener('submit', (e) => {
				if (cvSelect.value === '' && cvInput.files.length === 0) {
					e.preventDefault();
					alert('Veuillez fournir un CV.');
					return;
				}
				if (lmSelect.value === '' && lmInput.files.length === 0) {
					e.preventDefault();
					alert('Veuillez fournir une lettre de motivation.');
					return;
				}
				submitBtn.disabled = true;
			});
		});
	</script>
{% endblock %}
