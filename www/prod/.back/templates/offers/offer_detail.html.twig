{% extends "base.html.twig" %}

{% block title %}{{ offer.getDisplayTitle() }} - StageFlow{% endblock %}

{% block head %}
<style>
    /* Layout épuré type Dashboard */
    .detail-layout {
        display: grid;
        grid-template-columns: 1fr 300px;
        gap: 2rem;
        margin-top: 1.5rem;
    }

    /* Section principale */
    .content-card {
        background: var(--clr-surface);
        border: 1px solid var(--clr-border-light);
        padding: 2rem;
        border-radius: var(--border-radius);
    }

    .section-title {
        font-size: 1.1rem;
        font-weight: 600;
        color: var(--clr-text);
        margin-bottom: 1.2rem;
        border-bottom: 1px solid var(--clr-border-light);
        padding-bottom: 0.5rem;
    }

    /* Sidebar avec données structurées */
    .sidebar-info {
        position: sticky;
        top: 2rem;
    }

    .info-group {
        background: var(--clr-surface);
        border: 1px solid var(--clr-border-light);
        border-radius: var(--border-radius);
        padding: 1.25rem;
        margin-bottom: 1rem;
    }

    .data-row {
        display: flex;
        justify-content: space-between;
        font-size: 0.9rem;
        padding: 0.6rem 0;
        border-bottom: 1px solid var(--clr-bg);
    }

    .data-row:last-child { border-bottom: none; }

    .data-label { color: var(--clr-text-muted); }
    .data-value { font-weight: 500; color: var(--clr-text); }

    .skill-pills {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        margin-top: 1rem;
    }

    /* Override tag pour un look plus subtil */
    .tag {
        font-weight: 500;
        text-transform: capitalize;
        letter-spacing: normal;
    }

    @media (max-width: 850px) {
        .detail-layout { grid-template-columns: 1fr; }
    }
</style>
{% endblock %}

{% block body %}
<main>
    <div style="margin-bottom: 1rem;">
        <a href="../index.php" class="btn btn-ghost" style="text-decoration: none;">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right: 4px; vertical-align: middle;"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
            Retour aux offres
        </a>
    </div>

    <div class="page-header" style="border-bottom: none; margin-bottom: 2rem;">
        <div>
            <span class="tag {{ offer.state|lower }}">{{ offer.state }}</span>
            <h1 style="font-size: 1.8rem; margin-top: 0.75rem;">{{ offer.getDisplayTitle() }}</h1>
            <p class="text-muted" style="font-size: 1rem;">
                <span style="color: var(--clr-text);">{{ offer.company_name }}</span> • {{ offer.location }}
            </p>
        </div>
        <div>
            {% if alreadyApplied %}
                <button class="btn" disabled style="opacity: 0.6; cursor: not-allowed;">Candidature envoyée</button>
            {% else %}
                <a href="apply.php?id={{ offer.id }}" class="btn btn-primary" style="padding: 0.6rem 1.5rem;">Postuler</a>
            {% endif %}
        </div>
    </div>

    <div class="detail-layout">
        <div class="main-content">
            <section class="content-card">
                <h2 class="section-title">Description du poste</h2>
                <div style="white-space: pre-line; color: var(--clr-text); line-height: 1.7;">
                    {{ offer.description }}
                </div>

                {% set skills = offer.getSkillsArray() %}
                {% if skills is not empty %}
                    <h2 class="section-title" style="margin-top: 2.5rem;">Compétences clés</h2>
                    <div class="skill-pills">
                        {% for skill in skills %}
                            <span class="tag tag-slate">{{ skill }}</span>
                        {% endfor %}
                    </div>
                {% endif %}
            </section>
        </div>

        <aside class="sidebar-info">
            <div class="info-group">
                <h3 style="font-size: 0.9rem; margin-bottom: 1rem; color: var(--clr-text-muted);">DÉTAILS DE L'OFFRE</h3>
                
                <div class="data-row">
                    <span class="data-label">Salaire</span>
                    <span class="data-value">{{ offer.formatSalary() }}</span>
                </div>
                <div class="data-row">
                    <span class="data-label">Contrat</span>
                    <span class="data-value">{{ offer.job_type|capitalize }}</span>
                </div>
                <div class="data-row">
                    <span class="data-label">Télétravail</span>
                    <span class="data-value">{{ offer.remote_type|default('Non renseigné')|capitalize }}</span>
                </div>
                <div class="data-row">
                    <span class="data-label">Niveau d'études</span>
                    <span class="data-value">{{ offer.education_level|default('N/A')|upper }}</span>
                </div>
            </div>

            <div class="info-group" style="background: transparent; border: 1px dashed var(--clr-border);">
                <p class="text-sm text-muted">
                    Publiée le {{ offer.created_at|date("d/m/Y") }}<br>
                    {{ offer.views_count }} vues au total
                </p>
            </div>
        </aside>
    </div>
</main>
{% endblock %}