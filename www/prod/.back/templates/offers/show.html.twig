{# .back/views/offers/show.html.twig #}
{% extends "base.html.twig" %}

{% block title %}
	{{ offer.title }}
	— StageFlow
{% endblock %}

{% block body %}
	<div class="page-header">
		<div>
			<a href="/app/offers" class="btn btn-ghost" style="border: none; padding-left: 0;">← Retour au catalogue</a>
			<h1 class="mt-1">{{ offer.title }}</h1>
			<p>Publié le
				{{ offer.published_at|date("d/m/Y") }}
				par
				<strong>{{ offer.company_name }}</strong>
			</p>
		</div>

		<div
			style="display: flex; gap: 10px; align-items: center;">
			{# Student Actions: Wishlist #}
			{% if currentRole == 'student' %}
				<form action="/app/wishlist/toggle/{{ offer.id }}" method="POST" style="display:inline;">
					<input type="hidden" name="csrf_token" value="{{ csrf_token }}">
					<button type="submit" class="btn {{ isWishlisted ? 'btn-danger' : 'btn-outline' }}">
						{{ isWishlisted ? '💔 Retirer de la wishlist' : '❤️ Ajouter à la wishlist' }}
					</button>
				</form>
			{% endif %}

			{# Admin/Pilot Actions: Edit & Delete #}
			{% if isPrivileged %}
				<a href="/app/offers/edit/{{ offer.id }}" class="btn btn-outline">Modifier</a>

				<form action="/app/offers/delete/{{ offer.id }}" method="POST" onsubmit="return confirm('Archiver cette offre ?');" style="display:inline;">
					<input type="hidden" name="csrf_token" value="{{ csrf_token }}">
					<button type="submit" class="btn btn-danger">Supprimer</button>
				</form>
			{% endif %}
		</div>
	</div>

	<div class="profile-layout">
		<aside>
			<div class="card user-card">
				<div class="avatar-circle">🏢</div>
				<h3>{{ offer.company_name }}</h3>
				<p class="text-sm text-muted">{{ offer.location }}</p>

				<div class="data-grid mt-3" style="text-align: left;">
					<div class="data-item">
						<span class="data-label">Gratification</span>
						<span class="data-value">{{ offer.hourly_rate|default('N/C') }}
							€/h</span>
					</div>
					<div class="data-item">
						<span class="data-label">Durée</span>
						<span class="data-value">{{ offer.duration_weeks|default('?') }}
							semaines</span>
					</div>
					<div class="data-item">
						<span class="data-label">Début</span>
						<span class="data-value">{{ offer.start_date ? offer.start_date|date("d/m/Y") : 'À définir' }}</span>
					</div>
				</div>

				{# Apply Button: Usually only for students #}
				{% if currentRole == 'student' %}
					<a href="/app/offers/{{ offer.id }}/apply" class="btn btn-primary w-100 mt-3" style="display: block; text-align: center; padding: 10px; text-decoration: none;">
						Postuler via StageFlow
					</a>
				{% endif %}
			</div>

			<div class="notice notice-warn mt-2">
				<p class="text-sm">
					<strong>Attention :</strong>
					Ne partagez jamais vos coordonnées bancaires lors d'une candidature.</p>
			</div>
		</aside>

		<section>
			<div class="legal-section">
				<div class="legal-section-header">
					<h2>Description du poste</h2>
				</div>
				<div class="legal-section-body">
					<p style="white-space: pre-wrap;">{{ offer.description|default('Aucune description fournie.') }}</p>
				</div>
			</div>

			{# .back/views/offers/show.html.twig #}

			{% if skills is not empty %}
				<div class="legal-section mt-2">
					<div class="legal-section-header">
						<h2>Compétences requises</h2>
					</div>
					<div
						class="legal-section-body">
						{# We use your container class to handle the gap and flex layout #}
						<div class="skills-container" style="border: none; padding: 0;">
							{% for skill in skills %}
								<div class="skill-tag">
									{{ skill }}
									{# No button here because this is the view-only mode #}
								</div>
							{% endfor %}
						</div>
					</div>
				</div>
			{% endif %}
		</section>
	</div>
{% endblock %}
