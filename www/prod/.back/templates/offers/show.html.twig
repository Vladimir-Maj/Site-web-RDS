{# .back/views/offers/show.html.twig #}
{% extends "base.html.twig" %}

{% block title %}
	{{ offer.title }}
	— StageFlow
{% endblock %}

{% block body %}
	<div class="page-header">
		<div>
			<a href="{{ from == 'home' ? '/' : '/app/offers' }}" class="btn btn-ghost" style="border: none; padding-left: 0;">
				{{ from == 'home' ? '← Retour à l’accueil' : '← Retour aux offres' }}
			</a>
			<h1 class="mt-1">{{ offer.title }}</h1>
			<p>Publié le
				{{ offer.published_at|date("d/m/Y") }}
				par
				<strong>{{ offer.company_name }}</strong>
			</p>
		</div>

		<div style="display: flex; gap: 10px; align-items: center;">
			{% if currentRole == 'student' %}
				<form action="/app/wishlist/toggle/{{ offer.id }}" method="POST" style="display:inline;">
					<input type="hidden" name="csrf_token" value="{{ csrf_token }}">
					<button type="submit" class="btn {{ isWishlisted ? 'btn-danger' : 'btn-outline' }}">
						{{ isWishlisted ? '💔 Retirer de la wishlist' : '❤️ Ajouter à la wishlist' }}
					</button>
				</form>
			{% endif %}

			{% if isPrivileged %}
				<a href="/app/offers/edit/{{ offer.id }}" class="btn btn-outline">Modifier</a>

				<form action="/app/offers/delete/{{ offer.id }}" method="POST" onsubmit="return confirm('Archiver cette offre ?');" style="display:inline;">
					<input type="hidden" name="csrf_token" value="{{ csrf_token }}">
					<button type="submit" class="btn btn-danger">Supprimer</button>
				</form>
			{% endif %}
		</div>
	</div>

	<div class="profile-layout">
		<aside>
			<div class="card user-card">
				<div class="avatar-circle">🏢</div>
				<h3>{{ offer.company_name }}</h3>
				<p class="text-sm text-muted">{{ offer.location }}</p>

				<div class="data-grid mt-3" style="text-align: left;">
					<div class="data-item">
						<span class="data-label">Gratification</span>
						<span class="data-value">{{ offer.hourly_rate|default('N/C') }} €/h</span>
					</div>
					<div class="data-item">
						<span class="data-label">Durée</span>
						<span class="data-value">{{ offer.duration_weeks|default('?') }} semaines</span>
					</div>
					<div class="data-item">
						<span class="data-label">Début</span>
						<span class="data-value">{{ offer.start_date ? offer.start_date|date("d/m/Y") : 'À définir' }}</span>
					</div>
				</div>

				{% if currentRole == 'student' %}
					<a href="/app/offers/{{ offer.id }}/apply" class="btn btn-primary w-100 mt-3" style="display: block; text-align: center; padding: 10px; text-decoration: none;">
						Postuler via StageFlow
					</a>
				{% endif %}
			</div>

			<div class="notice notice-warn mt-2">
				<p class="text-sm">
					<strong>Attention :</strong>
					Ne partagez jamais vos coordonnées bancaires lors d'une candidature.
				</p>
			</div>

			{# ========================================================================
			   STATISTICS CARD — Displays view count and application count
			   ======================================================================== #}
			<div class="card mt-2" style="padding: 1.25rem; background-color: rgba(var(--primary-rgb), 0.03);">
				<p class="text-sm" style="text-transform: uppercase; letter-spacing: 1px; color: var(--primary-color); margin-bottom: 0.75rem;">
					Statistiques de l'offre
				</p>
				<div class="data-grid">
					<div class="data-item">
						<span class="data-label">👀 Vues</span>
						<span class="data-value">{{ views }}</span>
					</div>
					<div class="data-item">
						<span class="data-label">📩 Candidatures</span>
						<span class="data-value">{{ applications }}</span>
					</div>
				</div>

				{# Optional: Add a small social proof progress bar #}
				{% if applications > 10 %}
					<p class="text-xs text-muted mt-2">🔥 Offre très demandée !</p>
				{% endif %}
			</div>
		</aside>

		<section>
			<div class="legal-section">
				<div class="legal-section-header">
					<h2>Description du poste</h2>
				</div>
				<div class="legal-section-body">
					<p style="white-space: pre-wrap;">{{ offer.description|default('Aucune description fournie.') }}</p>
				</div>
			</div>

			{% if skills is not empty %}
				<div class="legal-section mt-2">
					<div class="legal-section-header">
						<h2>Compétences requises</h2>
					</div>
					<div class="legal-section-body">
						<div class="skills-container" style="border: none; padding: 0;">
							{% for skill in skills %}
								<div class="skill-tag">
									{{ skill }}
								</div>
							{% endfor %}
						</div>
					</div>
				</div>
			{% endif %}
		</section>
	</div>
{% endblock %}
