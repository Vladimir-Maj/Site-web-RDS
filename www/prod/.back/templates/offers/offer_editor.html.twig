{# .back/views/offers/offer_editor.html.twig #}
{% extends "base.html.twig" %}

{% block title %}{{ mode == 'edit' ? 'Modifier' : 'Publier' }} une offre — StageFlow{% endblock %}

{% block body %}
<div class="page-header">
    <div>
        <h1>{{ mode == 'edit' ? 'Édition de l\'offre' : 'Nouvelle Publication' }}</h1>
        <p>Diffusez vos opportunités de stage au sein du réseau CESI.</p>
    </div>
</div>

{# Use your global .notice classes for errors #}
{% if error %}
    <div class="notice notice-error">
        <div class="notice-icon">⚠️</div>
        <p><strong>Erreur :</strong> {{ error }}</p>
    </div>
{% endif %}

<div class="company-form card">
    <form action="{{ mode == 'edit' ? '/offers/update/' ~ offer.id : '/offers/store' }}" method="POST" class="card-body">
        
        <div class="info-section">
            <span class="section-label">Poste & Entreprise</span>
            <div class="form-grid">
                <div class="form-group span-full">
                    <label for="title">Titre de l'offre</label>
                    <input type="text" name="title" id="title" value="{{ offer.title }}" placeholder="ex: Développeur PHP Fullstack (H/F)" required>
                </div>

                <div class="form-group">
                    <label for="site_id">Site d'affectation</label>
                    <select name="site_id" id="site_id" required>
                        <option value="">— Choisir un site —</option>
                        {% for site in sites %}
                            <option value="{{ site.id }}" {{ offer.site_id == site.id ? 'selected' : '' }}>
                                {{ site.company_name }} ({{ site.city }})
                            </option>
                        {% endfor %}
                    </select>
                </div>

                <div class="form-group">
                    <label for="hourly_rate">Gratification (€/h)</label>
                    <input type="number" step="0.01" name="hourly_rate" id="hourly_rate" value="{{ offer.hourly_rate }}" placeholder="ex: 4.35">
                </div>
            </div>
        </div>

        <div class="info-section">
            <span class="section-label">Missions & Compétences</span>
            <div class="form-grid">
                <div class="form-group span-full">
                    <label for="description">Description détaillée</label>
                    <textarea name="description" id="description" rows="8" placeholder="Décrivez les missions, l'équipe et l'environnement technique...">{{ offer.description }}</textarea>
                </div>
                
                <div class="form-group">
                    <label for="start_date">Date de début prévue</label>
                    <input type="date" name="start_date" id="start_date" value="{{ offer.start_date }}">
                </div>

                <div class="form-group">
                    <label for="duration_weeks">Durée (en semaines)</label>
                    <input type="number" name="duration_weeks" id="duration_weeks" value="{{ offer.duration_weeks }}" placeholder="ex: 16">
                </div>
            </div>
        </div>

        <div class="info-section">
            <span class="section-label">Paramètres de publication</span>
            <div class="form-grid">
                <div class="form-group">
                    <label for="is_active">Visibilité</label>
                    <select name="is_active" id="is_active">
                        <option value="1" {{ offer.is_active ? 'selected' : '' }}>Publiée (Visible par tous)</option>
                        <option value="0" {{ not offer.is_active ? 'selected' : '' }}>Brouillon (Masquée)</option>
                    </select>
                </div>
            </div>
        </div>

        <div class="form-actions">
            <a href="/app/offers" class="btn btn-ghost">Annuler</a>
            <button type="submit" class="btn btn-primary">
                {{ mode == 'edit' ? 'Mettre à jour' : 'Publier l\'offre' }}
            </button>
        </div>
    </form>
</div>
{% endblock %}