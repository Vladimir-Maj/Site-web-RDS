{# .back/views/offers/offer_editor.html.twig #}
{% extends "dashboard/layout.html.twig" %}

{% block title %}
    {{ mode == 'edit' ? 'Modifier' : 'Publier' }} une offre — StageFlow
{% endblock %}

{% block dashboard_content %}
<div class="page-header">
    <div>
        <h1>{{ mode == 'edit' ? 'Édition de l\'offre' : 'Nouvelle Publication' }}</h1>
        <p>Diffusez vos opportunités de stage au sein du réseau CESI.</p>
    </div>
</div>

{% if error %}
    <div class="notice notice-error">
        <div class="notice-icon">⚠️</div>
        <p><strong>Erreur :</strong> {{ error }}</p>
    </div>
{% endif %}

<div class="company-form card">
    <form action="{{ mode == 'edit' ? '/dashboard/offers/update/' ~ offer.id : '/dashboard/offers/new' }}" method="POST" class="card-body">
        
        {# CSRF Security #}
        <input type="hidden" name="csrf_token" value="{{ csrf_token }}">

        <div class="info-section">
            <span class="section-label">Poste & Entreprise</span>
            <div class="form-grid">
                <div class="form-group span-full">
                    <label for="title">Titre de l'offre</label>
                    <input type="text" name="title" id="title" value="{{ offer.title }}" placeholder="ex: Développeur PHP Fullstack (H/F)" required>
                </div>

                {# 1. Company Selection (Triggers AJAX) #}
                <div class="form-group">
                    <label for="company_id">Entreprise</label>
                    <select name="company_id" id="company_id" required>
                        <option value="">— Choisir une entreprise —</option>
                        {% for company in companies %}
                            <option value="{{ company.id }}" {{ (offer.company_id == company.id) ? 'selected' : '' }}>
                                {{ company.name }}
                            </option>
                        {% endfor %}
                    </select>
                </div>

                {# 2. Dependent Site Selection #}
                <div class="form-group">
                    <label for="site_id">Site d'affectation</label>
                    <select name="site_id" id="site_id" required {{ mode != 'edit' ? 'disabled' : '' }}>
                        {% if mode == 'edit' %}
                            {% for site in sites %}
                                <option value="{{ site.id }}" {{ offer.site_id == site.id ? 'selected' : '' }}>
                                    {{ site.city }} ({{ site.address }})
                                </option>
                            {% endfor %}
                        {% else %}
                            <option value="">— Sélectionnez d'abord une entreprise —</option>
                        {% endif %}
                    </select>
                </div>

                <div class="form-group">
                    <label for="hourly_rate">Gratification (€/h)</label>
                    <input type="number" step="0.01" name="hourly_rate" id="hourly_rate" value="{{ offer.hourly_rate }}" placeholder="ex: 4.35">
                </div>
            </div>
        </div>

        <div class="info-section">
            <span class="section-label">Missions & Compétences</span>
            <div class="form-grid">
                <div class="form-group span-full">
                    <label for="description">Description détaillée</label>
                    <textarea name="description" id="description" rows="8" placeholder="Décrivez les missions, l'équipe et l'environnement technique...">{{ offer.description }}</textarea>
                </div>
                <div class="form-group">
                    <label for="start_date">Date de début prévue</label>
                    <input type="date" name="start_date" id="start_date" value="{{ offer.start_date }}">
                </div>
                <div class="form-group">
                    <label for="duration_weeks">Durée (en semaines)</label>
                    <input type="number" name="duration_weeks" id="duration_weeks" value="{{ offer.duration_weeks }}" placeholder="ex: 16">
                </div>
            </div>
        </div>

        <div class="info-section">
            <span class="section-label">Paramètres de publication</span>
            <div class="form-grid">
                <div class="form-group">
                    <label for="is_active">Visibilité</label>
                    <select name="is_active" id="is_active">
                        <option value="1" {{ offer.is_active ? 'selected' : '' }}>Publiée (Visible par tous)</option>
                        <option value="0" {{ not offer.is_active ? 'selected' : '' }}>Brouillon (Masquée)</option>
                    </select>
                </div>
            </div>
        </div>

        <div class="form-actions">
            <a href="/dashboard/offers" class="btn btn-ghost">Annuler</a>
            <button type="submit" class="btn btn-primary">
                {{ mode == 'edit' ? 'Mettre à jour' : 'Publier l\'offre' }}
            </button>
        </div>
    </form>
</div>

<script>
/**
 * Debug helper for remote logging
 */
const remoteLog = (message, data = {}) => {
    console.log(`[Debug] ${message}`, data);
};

document.addEventListener('DOMContentLoaded', function() {
    remoteLog("DOM Content Loaded - Script Initializing");

    const companySelect = document.getElementById('company_id');
    const siteSelect = document.getElementById('site_id');

    if (!companySelect || !siteSelect) {
        remoteLog("CRITICAL: Elements not found");
        return;
    }

    companySelect.addEventListener('change', function() {
        const companyId = this.value;
        
        if (!companyId) {
            siteSelect.innerHTML = '<option value="">— Sélectionnez d\'abord une entreprise —</option>';
            siteSelect.disabled = true;
            return;
        }

        // Use the dashboard-consistent API path
        const apiUrl = `/api/companies/${companyId}/sites`;
        remoteLog("Initiating Fetch", { url: apiUrl });

        fetch(apiUrl)
            .then(response => {
                if (!response.ok) throw new Error(`HTTP error! status: ${response.status}`);
                return response.json();
            })
            .then(data => {
                siteSelect.innerHTML = '<option value="">— Choisir un site —</option>';
                data.forEach(site => {
                    const option = document.createElement('option');
                    option.value = site.id;
                    option.textContent = `${site.city} (${site.address || ''})`;
                    siteSelect.appendChild(option);
                });
                siteSelect.disabled = false;
                remoteLog("Dropdown updated successfully");
            })
            .catch(error => {
                remoteLog("FETCH ERROR", { message: error.message });
            });
    });
});
</script>
{% endblock %}