{% extends "dashboard/layout.html.twig" %}

{% block title %}Catalogue des offres - StageFlow{% endblock %}

{% block dashboard_content %}
    <section class="offers-hero">
        <div class="offers-hero__content">
            <div>
                <h1>Catalogue des offres</h1>
                <p>
                    Explorez les opportunit魹ｽs disponibles, filtrez rapidement et acc魹ｽdez aux d魹ｽtails en un clic.
                </p>
            </div>

            {% if isPrivileged %}
                <div class="offers-hero__actions">
                    <a href="/dashboard/offers/new" class="btn btn-primary">+ Publier une offre</a>
                </div>
            {% endif %}
        </div>
    </section>

    <section class="offers-toolbar card">
        <div class="offers-toolbar__top">
            <div>
                <h2>Rechercher une offre</h2>
                <p>Affinez le catalogue par mot-cl魹ｽ ou par localisation.</p>
            </div>

            <div class="offers-toolbar__stats">
                <span class="offers-stat-pill">
                    {{ offers|length }} r魹ｽsultat{{ offers|length > 1 ? 's' : '' }}
                </span>

                {% if totalPages > 1 %}
                    <span class="offers-stat-pill">
                        Page {{ page }} / {{ totalPages }}
                    </span>
                {% endif %}
            </div>
        </div>

        <form method="GET" action="/app/offers" class="offer-search-form">
            <div class="form-group">
                <label for="keyword">Mot-cl魹ｽ</label>
                <input
                        id="keyword"
                        type="text"
                        name="keyword"
                        placeholder="Titre, entreprise..."
                        value="{{ filters.keyword|default('') }}"
                >
            </div>

            <div class="form-group">
                <label for="city">Localisation</label>
                <input
                        id="city"
                        type="text"
                        name="city"
                        placeholder="Ville (ex : Nancy)"
                        value="{{ filters.city|default('') }}"
                >
            </div>

            <button type="submit" class="btn btn-primary">Filtrer</button>
            <a href="/app/offers" class="btn btn-ghost">R魹ｽinitialiser</a>
        </form>

        {% set hasKeyword = filters.keyword is defined and filters.keyword is not empty %}
        {% set hasCity = filters.city is defined and filters.city is not empty %}

        {% if hasKeyword or hasCity %}
            <div class="offers-active-filters">
                <span class="offers-active-filters__label">Filtres actifs :</span>

                {% if hasKeyword %}
                    <span class="offers-filter-chip">Mot-cl魹ｽ : {{ filters.keyword }}</span>
                {% endif %}

                {% if hasCity %}
                    <span class="offers-filter-chip">Ville : {{ filters.city }}</span>
                {% endif %}
            </div>
        {% endif %}
    </section>

    <div class="notice notice-info offers-info-notice">
        <p>
            Il y a actuellement
            <strong>{{ offers|length }} offre{{ offers|length > 1 ? 's' : '' }}</strong>
            correspondant 魹ｽ vos crit魹ｽres.
        </p>
    </div>

    <div class="offer-list">
        {% for offer in offers %}
            {{ include('components/card_template.twig', {
                'offer': offer,
                'isPrivileged': isPrivileged
            }) }}
        {% else %}
            <div class="card offers-empty-state">
                <h3>Aucune offre ne correspond 魹ｽ votre recherche</h3>
                <p>
                    Essayez d?魹ｽlargir vos crit魹ｽres ou r魹ｽinitialisez les filtres pour afficher plus d?opportunit魹ｽs.
                </p>

                <div class="offers-empty-state__actions">
                    <a href="/app/offers" class="btn btn-ghost">R魹ｽinitialiser les filtres</a>

                    {% if isPrivileged %}
                        <a href="/dashboard/offers/new" class="btn btn-primary">Publier une offre</a>
                    {% endif %}
                </div>
            </div>
        {% endfor %}
    </div>

    {% if totalPages > 1 %}
        <div class="pagination offers-pagination">
            {% set queryPrefix = '?keyword=' ‾ (filters.keyword|default('')|url_encode) ‾ '&city=' ‾ (filters.city|default('')|url_encode) ‾ '&page=' %}

            {% if page > 1 %}
                <a href="{{ queryPrefix ‾ (page - 1) }}" class="btn btn-ghost">Pr魹ｽc魹ｽdent</a>
            {% endif %}

            <span class="page-info">
                Page <strong>{{ page }}</strong> sur {{ totalPages }}
            </span>

            {% if page < totalPages %}
                <a href="{{ queryPrefix ‾ (page + 1) }}" class="btn btn-ghost">Suivant</a>
            {% endif %}
        </div>
    {% endif %}
{% endblock %}
