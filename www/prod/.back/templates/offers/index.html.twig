{# .back/views/offers/index.html.twig #}
{% extends "dashboard/layout.html.twig" %}

{% block title %}Catalogue des offres - StageFlow{% endblock %}

{% block dashboard_content %}
    <div class="page-header">
        <div>
            <h1>Catalogue des offres</h1>
            <p>Gestion centrale des opportunit�s de stage et d'emploi.</p>
        </div>

        {% if isPrivileged %}
            <div style="display: flex; gap: 10px;">
                <a href="/dashboard/offers/new" class="btn btn-primary">+ Publier</a>
            </div>
        {% endif %}
    </div>

    <form method="GET" action="/app/offers" class="search-bar offer-search-form">
        <div class="form-group">
            <label for="keyword">Mots-cl�s</label>
            <input id="keyword" type="text" name="keyword" placeholder="Titre, entreprise..." value="{{ filters.keyword|default('') }}">
        </div>

        <div class="form-group">
            <label for="city">Localisation</label>
            <input id="city" type="text" name="city" placeholder="Ville (ex : Nancy)" value="{{ filters.city|default('') }}">
        </div>

        <button type="submit" class="btn btn-primary">Filtrer</button>
        <a href="/app/offers" class="btn btn-ghost">R�initialiser</a>
    </form>

    <div class="notice notice-info">
        <div class="notice-icon">i</div>
        <p>
            Il y a actuellement <strong>{{ offers|length }} offre{{ offers|length > 1 ? 's' : '' }}</strong>
            correspondant � vos crit�res.
        </p>
    </div>

    <div class="offer-list">
        {% for offer in offers %}
            {{ include('components/card_template.twig', {'offer': offer, 'isPrivileged': isPrivileged}) }}
        {% else %}
            <div class="card" style="padding: 2rem; text-align: center;">
                <p class="text-muted">Aucune offre ne correspond � votre recherche.</p>
            </div>
        {% endfor %}
    </div>

    {% if totalPages > 1 %}
        <div class="pagination" style="display: flex; justify-content: center; gap: 15px; margin-top: 3rem; align-items: center; flex-wrap: wrap;">
            {% if page > 1 %}
                <a href="?page={{ page - 1 }}" class="btn btn-ghost">Pr�c�dent</a>
            {% endif %}

            <span class="text-sm">Page <strong>{{ page }}</strong> sur {{ totalPages }}</span>

            {% if page < totalPages %}
                <a href="?page={{ page + 1 }}" class="btn btn-ghost">Suivant</a>
            {% endif %}
        </div>
    {% endif %}
{% endblock %}
