<header id="page-header">
	<div class="header-inner">
		<a href="/" class="logo">
			<span></span>euh prosit 6-7
		</a>

		{# Burger button — Now visible on ALL screens #}
		<button class="burger" id="burger-toggle" aria-label="Ouvrir le menu" aria-expanded="false" aria-controls="main-nav">
			<span></span>
			<span></span>
			<span></span>
		</button>

		<nav id="main-nav">
			<div class="nav-content">
				<a href="/dashboard/offers" class="{{ currentPage|default('') == 'search' ? 'active' : '' }}">Offres</a>

				{% if user and (user.role == 'admin' or user.role == 'pilote') %}
					<a href="/dashboard/offers/new" class="{{ currentPage|default('') == 'editor' ? 'active' : '' }}">Publier</a>
					<a href="/app/skills" class="{{ currentPage|default('') == 'skills' ? 'active' : '' }}">Compétences</a>
					<a href="/app/companies" class="{{ currentPage|default('') == 'companies' ? 'active' : '' }}">Entreprises</a>
				{% endif %}



				{% if user %}
					<a href="/profile" class="{{ currentPage|default('') == 'profile' ? 'active' : '' }}">
						Profil ({{ user.first_name|default('PRENOM') }})
					</a>
					<a href="/logout" class="logout-link">Logout</a>
				{% else %}
					<a href="/login" class="{{ currentPage|default('') == 'login' ? 'active' : '' }}">Connexion</a>
				{% endif %}

				<hr class="nav-divider">

				<div class="nav-footer">
					<span>Theme:</span>
					<button id="theme-toggle" class="btn btn-theme">Light / Dark</button>
				</div>
			</div>
		</nav>
	</div>
</header>

<style>
	/* ── Header Structure ── */
	header {
		position: sticky;
		top: 0;
		z-index: 1000;
		background: var(--clr-accent);
		color: var(--clr-accent-inv);
		border-bottom: 2px solid var(--clr-border);
	}

	.header-inner {
		max-width: var(--container-max-width, 1000px);
		margin: 0 auto;
		padding: 0.75rem 1.2rem;
		display: flex;
		align-items: center;
		justify-content: space-between;
	}

	/* ── Burger Button (Always Visible) ── */
	.burger {
		display: flex; /* Forced display */
		flex-direction: column;
		justify-content: center;
		gap: 5px;
		background: none;
		border: none;
		cursor: pointer;
		padding: 8px;
		color: var(--clr-accent-inv);
		z-index: 1100;
	}

	.burger span {
		display: block;
		width: 24px;
		height: 2px;
		background: currentColor;
		border-radius: 2px;
		transition: 0.3s cubic-bezier(0.4, 0, 0.2, 1);
	}

	/* Burger Animation X */
	.burger[aria-expanded="true"] span:nth-child(1) {
		transform: translateY(7px) rotate(45deg);
	}
	.burger[aria-expanded="true"] span:nth-child(2) {
		opacity: 0;
		transform: scaleX(0);
	}
	.burger[aria-expanded="true"] span:nth-child(3) {
		transform: translateY(-7px) rotate(-45deg);
	}

	/* ── The Menu (Overlay Style) ── */
	#main-nav {
		display: none; /* Hidden state */
		position: absolute;
		top: 100%;
		right: 0;
		width: 100%;
		max-width: 320px; /* Limits width on Desktop for a sidebar look */
		background: var(--clr-surface);
		border: 1px solid var(--clr-border);
		border-top: none;
		box-shadow: -10px 10px 30px rgba(0, 0, 0, 0.1);
		z-index: 1050;
		animation: slideIn 0.25s ease-out;
	}

	#main-nav.is-open {
		display: block;
	}

	.nav-content {
		display: flex;
		flex-direction: column;
		padding: 1rem;
	}

	#main-nav a {
		display: block;
		padding: 1rem;
		color: var(--clr-text);
		text-decoration: none;
		font-weight: 500;
		border-radius: var(--border-radius-btn);
		transition: background 0.2s;
	}

	#main-nav a:hover {
		background: var(--clr-bg);
	}

	#main-nav a.active {
		background: var(--clr-accent);
		color: var(--clr-accent-inv);
	}

	.logout-link {
		color: var(--clr-danger) !important;
		margin-top: 0.5rem;
	}

	.nav-divider {
		border: none;
		border-top: 1px solid var(--clr-border-light);
		margin: 1rem 0;
	}

	.nav-footer {
		padding: 0.5rem 1rem;
		display: flex;
		align-items: center;
		justify-content: space-between;
		font-size: 0.85rem;
		color: var(--clr-text-muted);
	}

	/* ── Desktop Tweaks ── */
	@media(min-width: 769px) {
		#main-nav {
			/* On desktop, make it look like a floating panel */
			right: 1.2rem;
			border-radius: 0 0 var(--border-radius) var(--border-radius);
		}
	}

	@keyframes slideIn {
		from {
			opacity: 0;
			transform: translateY(-10px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}
</style>

 <script>
  (function () {
    const burger = document.getElementById('burger-toggle');
    const nav    = document.getElementById('main-nav');

    burger.addEventListener('click', (e) => {
      e.stopPropagation();
      const isOpen = nav.classList.toggle('is-open');
      burger.setAttribute('aria-expanded', isOpen);
    });

    // Close on outside click
    document.addEventListener('click', (e) => {
      if (!nav.contains(e.target) && !burger.contains(e.target)) {
        nav.classList.remove('is-open');
        burger.setAttribute('aria-expanded', 'false');
      }
    });

    // Esc key to close
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        nav.classList.remove('is-open');
        burger.setAttribute('aria-expanded', 'false');
      }
    });
  })();

  (function () {
    const themeToggle = document.getElementById('theme-toggle');
    const htmlElement = document.documentElement;
    
    // 1. Function to set the theme
    const setTheme = (theme) => {
        htmlElement.setAttribute('data-theme', theme);
        localStorage.setItem('stageflow-theme', theme);
        
        // Update button text or icon based on theme
        themeToggle.innerText = theme === 'dark' ? '☀️ Light' : '🌙 Dark';
    };

    // 2. Determine initial theme
    const savedTheme = localStorage.getItem('stageflow-theme');
    const systemPrefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;

    if (savedTheme) {
        setTheme(savedTheme);
    } else if (systemPrefersDark) {
        setTheme('dark');
    } else {
        setTheme('light');
    }

    // 3. Toggle event listener
    themeToggle.addEventListener('click', () => {
        const currentTheme = htmlElement.getAttribute('data-theme');
        const newTheme = currentTheme === 'dark' ? 'light' : 'dark';
        setTheme(newTheme);
    });
})();

</script>
