{% set role = currentRole
	|default(currentUser.role.value
	|default(currentUser.role
		|default(user.role.value
			|default(user.role
				|default('guest')))))
%}

<header id="page-header">
	<div class="header-inner">
		<a href="/" class="logo" aria-label="Retour � l'accueil StageFlow">StageFlow</a>

		<button
				class="burger"
				id="burger-toggle"
				type="button"
				aria-label="Ouvrir le menu"
				aria-expanded="false"
				aria-controls="main-nav"
		>
			<span></span>
			<span></span>
			<span></span>
		</button>

		<nav id="main-nav" aria-label="Navigation principale">
			<div class="nav-content">
				<a href="/app/offers">Offres</a>
				<a href="/legals">Mentions l�gales</a>

				{% if isLoggedIn %}
					<hr class="nav-divider">

					{% if role in ['admin', 'pilote'] %}
						<a href="/dashboard/offers">Tableau de bord</a>
					{% elseif role == 'student' %}
						<a href="/">Accueil</a>
					{% endif %}

					<a href="/profile">
						Profil
						{% if currentUser and currentUser.first_name is defined %}
							({{ currentUser.first_name }})
						{% elseif user and user.first_name is defined %}
							({{ user.first_name }})
						{% endif %}
					</a>

					{% if role == 'student' %}
						<a href="/dashboard/wishlist">Ma wishlist</a>
						<a href="/dashboard/applications">Mes candidatures</a>
					{% endif %}

					<a href="/logout" class="logout-link">D�connexion</a>
				{% else %}
					<hr class="nav-divider">
					<a href="/login">Connexion</a>
					<a href="/register">Inscription</a>
				{% endif %}

				<hr class="nav-divider">

				<div class="nav-footer">
					<span>Th�me</span>
					<button id="theme-toggle" class="btn btn-theme" type="button">? Dark</button>
				</div>
			</div>
		</nav>
	</div>
</header>

<style>
	#page-header {
		position: sticky;
		top: 0;
		z-index: 5000;
		background: var(--clr-accent);
		color: var(--clr-accent-inv);
		border-bottom: 2px solid var(--clr-border);
	}

	.header-inner {
		max-width: var(--container-max-width, 1000px);
		margin: 0 auto;
		padding: 0.75rem 1.2rem;
		display: flex;
		align-items: center;
		justify-content: space-between;
	}

	.logo {
		color: inherit;
		text-decoration: none;
		font-weight: 700;
	}

	.burger {
		display: flex;
		flex-direction: column;
		gap: 5px;
		background: none;
		border: none;
		cursor: pointer;
		padding: 8px;
		color: currentColor;
	}

	.burger span {
		display: block;
		width: 24px;
		height: 2px;
		background: currentColor;
		border-radius: 2px;
		transition: 0.3s ease;
	}

	.burger[aria-expanded="true"] span:nth-child(1) {
		transform: translateY(7px) rotate(45deg);
	}

	.burger[aria-expanded="true"] span:nth-child(2) {
		opacity: 0;
	}

	.burger[aria-expanded="true"] span:nth-child(3) {
		transform: translateY(-7px) rotate(-45deg);
	}

	#main-nav {
		display: none;
		position: absolute;
		top: 100%;
		right: 0;
		width: 100%;
		max-width: 320px;
		background: var(--clr-surface);
		border: 1px solid var(--clr-border);
		border-top: none;
		box-shadow: -10px 10px 30px rgba(0, 0, 0, 0.1);
	}

	#main-nav.is-open {
		display: block;
	}

	.nav-content {
		display: flex;
		flex-direction: column;
		padding: 1rem;
	}

	#main-nav a {
		display: block;
		padding: 0.9rem 1rem;
		color: var(--clr-text);
		text-decoration: none;
		font-weight: 500;
		border-radius: var(--border-radius-btn);
	}

	#main-nav a:hover {
		background: var(--clr-bg);
	}

	.logout-link {
		color: var(--clr-danger) !important;
	}

	.nav-divider {
		border: none;
		border-top: 1px solid var(--clr-border-light);
		margin: 1rem 0;
	}

	.nav-footer {
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 0.5rem;
	}

	@media (min-width: 769px) {
		#main-nav {
			right: 1.2rem;
			border-radius: 0 0 var(--border-radius) var(--border-radius);
		}
	}
</style>

<script>
	(function () {
		const burger = document.getElementById('burger-toggle');
		const nav = document.getElementById('main-nav');
		const themeToggle = document.getElementById('theme-toggle');

		if (!burger || !nav || !themeToggle) return;

		// Gestion du menu mobile
		burger.addEventListener('click', function (event) {
			event.stopPropagation();
			const isOpen = nav.classList.toggle('is-open');
			burger.setAttribute('aria-expanded', String(isOpen));
		});

		// Fermeture au clic � l'ext�rieur
		document.addEventListener('click', function (event) {
			if (!nav.contains(event.target) && !burger.contains(event.target)) {
				nav.classList.remove('is-open');
				burger.setAttribute('aria-expanded', 'false');
			}
		});

		// Fermeture avec la touche �chap
		document.addEventListener('keydown', function (event) {
			if (event.key === 'Escape') {
				nav.classList.remove('is-open');
				burger.setAttribute('aria-expanded', 'false');
			}
		});

		// Logique du th�me
		const setTheme = function (theme) {
			if (theme === 'dark') {
				document.documentElement.setAttribute('data-theme', 'dark');
				themeToggle.textContent = '?? Light';
			} else {
				document.documentElement.removeAttribute('data-theme');
				themeToggle.textContent = '? Dark';
			}

			try {
				localStorage.setItem('stageflow-theme', theme);
			} catch (error) {
				// Ignore silent errors
			}
		};

		const currentTheme = document.documentElement.getAttribute('data-theme') === 'dark' ? 'dark' : 'light';
		setTheme(currentTheme);

		themeToggle.addEventListener('click', function () {
			const activeTheme = document.documentElement.getAttribute('data-theme') === 'dark' ? 'dark' : 'light';
			setTheme(activeTheme === 'dark' ? 'light' : 'dark');
		});
	})();
</script>
