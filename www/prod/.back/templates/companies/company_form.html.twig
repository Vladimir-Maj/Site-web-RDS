{% extends "base.html.twig" %}

{% set isNew = (id == 'new') %}
{% set companyName = company.name|default('') %}

{% block title %}
    {{ isNew ? 'Créer une Entreprise' : 'Modifier ' ~ companyName }} — SF Prosit
{% endblock %}

{% block body %}
<div class="page-wrapper">
    <main class="main">

        <header class="page-header mt-3">
            <h1>{{ isNew ? 'Nouvelle Entreprise' : 'Modifier l\'entreprise' }}</h1>
            <p>Gérez les informations légales et de contact de l'organisation.</p>
        </header>

        {% if error %}
            <div class="notice notice-error">
                <strong>Erreur :</strong> {{ error }}
            </div>
        {% endif %}

        <form action="/app/companies/{{ id }}" method="POST" class="card company-form mt-2">
            
            <input type="hidden" name="csrf_token" value="{{ csrf_token }}">

            <div class="card-body">

                {% if success %}
                    <div class="notice notice-success">Données enregistrées avec succès !</div>
                {% endif %}

                {# --- Section 1: Identité & Identifiant Légal --- #}
                <div class="info-section">
                    <span class="section-label">Identité & Légal</span>
                    <div class="form-grid">
                        <div class="form-group">
                            <label for="name">Nom de l'entreprise</label>
                            <input type="text" name="name" id="name" value="{{ companyName }}" placeholder="ex: Tech Solutions SAS" required>
                        </div>
                        <div class="form-group">
                            <label for="siren">Numéro SIREN</label>
                            <input type="text" name="siren" id="siren" 
                                   value="{{ company.siren|default('') }}" 
                                   placeholder="9 chiffres (ex: 123456789)" 
                                   pattern="[0-9]{9}" title="Le SIREN doit comporter 9 chiffres." required>
                        </div>
                    </div>
                </div>

                {# --- Section 2: Contact (Optionnel) --- #}
                <div class="info-section mt-2">
                    <span class="section-label">Contact & Web</span>
                    <div class="form-grid">
                        <div class="form-group">
                            <label for="email">Email de contact <span class="text-muted">(optionnel)</span></label>
                            <input type="email" name="email" id="email" value="{{ company.email|default('') }}" placeholder="contact@entreprise.fr">
                        </div>
                        <div class="form-group">
                            <label for="phone">Téléphone <span class="text-muted">(optionnel)</span></label>
                            <input type="tel" name="phone" id="phone" value="{{ company.phone|default('') }}" placeholder="01 23 45 67 89">
                        </div>
                        <div class="form-group span-full">
                            <label for="website">Site Web</label>
                            <input type="url" name="website" id="website" value="{{ company.website|default('') }}" placeholder="https://www.entreprise.fr">
                        </div>
                    </div>
                </div>

                {# --- Section 3: Localisation & Visuel --- #}
                <div class="info-section mt-2">
                    <span class="section-label">Localisation & Visuel</span>
                    <div class="form-grid">
                        <div class="form-group">
                            <label for="location">Siège Social</label>
                            <input type="text" name="location" id="location" value="{{ company.location|default('') }}" placeholder="Ville, Pays">
                        </div>
                        <div class="form-group">
                            <label for="logo_url">URL du Logo</label>
                            <input type="text" name="logo_url" id="logo_url" value="{{ company.logo_url|default('') }}" placeholder="https://...">
                        </div>
                    </div>
                </div>

                {# --- Section 4: Description --- #}
                <div class="info-section mt-2">
                    <span class="section-label">À propos</span>
                    <div class="form-group">
                        <label for="description">Description</label>
                        <textarea name="description" id="description" rows="5">{{ company.description|default('') }}</textarea>
                    </div>
                </div>

                {# --- Section 5: Classification & Statut --- #}
                <div class="info-section mt-2">
                    <span class="section-label">Paramètres</span>
                    <div class="form-grid">
                        <div class="form-group">
                            <label for="sector_id">Secteur d'activité</label>
                            <select name="sector_id" id="sector_id" required>
                                <option value="" disabled {{ company.sector_id is not defined ? 'selected' : '' }}>-- Choisir --</option>
                                {% for sector in sectors %}
                                    <option value="{{ sector.id }}" {{ (company.sector_id|default('') == sector.id) ? 'selected' : '' }}>
                                        {{ sector.name }}
                                    </option>
                                {% endfor %}
                            </select>
                        </div>
                        <div class="form-group">
                            <label for="status">Statut</label>
                            {% set isActive = isNew ? true : (company.is_active|default(false)) %}
                            <select name="status" id="status">
                                <option value="active" {{ isActive ? 'selected' : '' }}>Actif (Visible)</option>
                                <option value="pending" {{ not isActive ? 'selected' : '' }}>En attente</option>
                            </select>
                        </div>
                    </div>
                </div>

                <div class="form-actions mt-3">
                    <a href="/app/companies" class="btn btn-ghost">Annuler</a>
                    <button type="submit" class="btn btn-primary">
                        {{ isNew ? 'Créer l\'entreprise' : 'Mettre à jour' }}
                    </button>
                </div>
            </div>
        </form>

    </main>
</div>
{% endblock %}