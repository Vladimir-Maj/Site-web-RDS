{% extends "dashboard/layout.html.twig" %}

{% block title %}Annuaire des entreprises — StageFlow{% endblock %}

{% block dashboard_content %}
    {# --- Header : Copie conforme du catalogue des offres --- #}
    <div class="page-header">
        <div>
            <h1>Annuaire des entreprises</h1>
            <p>Consultez et gérez les organisations partenaires de la plateforme.</p>
        </div>
        <div style="display: flex; gap: 10px;">
            <a href="/dashboard/companies/new" class="btn btn-primary">+ Nouvelle entreprise</a>
        </div>
    </div>

    {# --- Barre de recherche : Style Catalogue --- #}
    <form method="GET" action="/dashboard/companies" class="search-bar">
        <div class="form-group">
            <label>Mots-clés</label>
            <input type="text" name="name" placeholder="Nom, SIREN..." value="{{ filters.name|default('') }}">
        </div>
        <div class="form-group">
            <label>Secteur d'activité</label>
            <select name="sector_id">
                <option value="">Tous les secteurs</option>
                {% for sector in sectors %}
                    <option value="{{ sector.id }}" {{ filters.sector_id|default('') == sector.id ? 'selected' : '' }}>
                        {{ sector.name }}
                    </option>
                {% endfor %}
            </select>
        </div>
        <button type="submit" class="btn btn-primary">🔍 Filtrer</button>
        <a href="/dashboard/companies" class="btn btn-ghost">Réinitialiser</a>
    </form>

    {# --- Notice : Style Catalogue --- #}
    <div class="notice notice-info">
        <div class="notice-icon">ℹ️</div>
        <p>Il y a actuellement <strong>{{ companies|length }} entreprise{{ companies|length > 1 ? 's' : '' }}</strong> correspondant à vos critères.</p>
    </div>

    {# --- Liste des entreprises (Tableau propre) --- #}
    <div class="card p-0 overflow-hidden" style="margin-top: 1rem;">
        <div class="table-responsive">
            <table class="table">
                <thead>
                    <tr>
                        <th>Organisation</th>
                        <th>Secteur</th>
                        <th>Localisation</th>
                        <th>Statut</th>
                        <th class="text-right">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for company in companies %}
                        <tr>
                            <td>
                                <div class="company-info" style="display: flex; align-items: center; gap: 10px;">
                                    <div class="company-logo-placeholder" style="font-size: 1.5rem;">🏢</div>
                                    <div>
                                        <strong>{{ company.name }}</strong>
                                        <div class="text-xs text-muted">SIREN : {{ company.siren|default('NC') }}</div>
                                    </div>
                                </div>
                            </td>
                            <td class="text-sm">{{ company.sector_name|default('Général') }}</td>
                            <td class="text-sm">{{ company.location|default('-') }}</td>
                            <td>
                                <span class="badge {{ company.is_active ? 'badge-success' : 'badge-warning' }}">
                                    {{ company.is_active ? 'Actif' : 'En attente' }}
                                </span>
                            </td>
                            <td class="text-right">
                                <a href="/dashboard/companies/{{ company.id }}" class="btn btn-ghost btn-sm">Gérer</a>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="5" class="text-center p-4">
                                <p class="text-muted">Aucune entreprise trouvée.</p>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    {# --- Pagination : Style Catalogue --- #}
    {% set page = filters.page|default(1) %}
    <div class="pagination" style="display: flex; justify-content: center; gap: 15px; margin-top: 3rem; align-items: center;">
        {% if page > 1 %}
            <a href="?page={{ page - 1 }}" class="btn btn-ghost">← Précédent</a>
        {% endif %}
        
        <span class="text-sm">Page <strong>{{ page }}</strong></span>

        {% if companies|length >= 10 %}
            <a href="?page={{ page + 1 }}" class="btn btn-ghost">Suivant →</a>
        {% endif %}
    </div>
{% endblock %}