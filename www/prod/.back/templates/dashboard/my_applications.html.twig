{# .back/views/applications/index.html.twig #}
{% extends "dashboard/layout.html.twig" %}

{% block title %}
    {% if is_student %}Mes Candidatures{% else %}Candidatures de {{ student.first_name }} {{ student.last_name }}{% endif %}
    — StageFlow
{% endblock %}

{% block dashboard_content %}
    <div class="page-header">
        <div>
            {% if is_student %}
                <h1>Mes Candidatures</h1>
                <p>Suivi en temps réel de vos demandes de stage.</p>
            {% else %}
                <h1>Candidatures de {{ student.first_name }} {{ student.last_name }}</h1>
                <p>Administration — Étudiant <span class="text-xs text-muted" style="font-family: monospace;">#{{ student.id }}</span></p>
            {% endif %}
        </div>
    </div>

    {# --- SUMMARY NOTICE --- #}
    <div class="notice notice-info">
        <div class="notice-icon">ℹ️</div>
        <p>
            Il y a actuellement <strong>{{ applications|length }} candidature{{ applications|length > 1 ? 's' : '' }}</strong> enregistrée{{ applications|length > 1 ? 's' : '' }}.
        </p>
    </div>

    {# --- DATA TABLE (Strictly matching Student/Skills layout) --- #}
    <div class="card p-0 overflow-hidden">
        <table class="table">
            <thead>
                <tr>
                    <th>Offre Concernée</th>
                    <th>ID Candidature</th>
                    <th class="text-right">Statut</th>
                </tr>
            </thead>
            <tbody>
                {% for app in applications %}
                    <tr>
                        <td>
                            <div style="display: flex; flex-direction: column;">
                                <span style="font-weight: bold; color: var(--text-main);">Offre #{{ app.offer_id }}</span>
                                <span class="text-xs text-muted">Postulé le {{ app.created_at|default('N/A') }}</span>
                            </div>
                        </td>
                        <td>
                            <span class="text-xs text-muted" style="font-family: monospace;">#{{ app.id }}</span>
                        </td>
                        <td class="text-right">
                            {# Status Logic Mapping #}
                            {% set status_map = {
                                'pending':  {'label': 'En attente', 'color': 'var(--warning-color, #f1c40f)'},
                                'accepted': {'label': 'Acceptée',  'color': 'var(--success-color, #2ecc71)'},
                                'rejected': {'label': 'Refusée',   'color': 'var(--error-color, #e74c3c)'}
                            } %}
                            {% set current = status_map[app.status] | default({'label': app.status, 'color': 'var(--text-muted)'}) %}

                            <span class="badge" style="background: var(--bg-secondary); border: 1px solid {{ current.color }}; color: var(--text-main); font-weight: bold;">
                                {{ current.label|upper }}
                            </span>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="3" class="text-center p-4 text-muted">
                            Aucune candidature trouvée dans la base.
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

    {# --- PAGINATION (Strictly matching Offers layout) --- #}
    {% if totalPages is defined and totalPages > 1 %}
        <div class="pagination" style="display: flex; justify-content: center; gap: 15px; margin-top: 3rem; align-items: center;">
            {% if page > 1 %}
                <a href="?page={{ page - 1 }}" class="btn btn-ghost">← Précédent</a>
            {% endif %}
            <span class="text-sm">Page <strong>{{ page }}</strong> sur {{ totalPages }}</span>
            {% if page < totalPages %}
                <a href="?page={{ page + 1 }}" class="btn btn-ghost">Suivant →</a>
            {% endif %}
        </div>
    {% endif %}
{% endblock %}