{% extends "dashboard/layout.html.twig" %}

{% block title %}Tableau de bord — StageFlow{% endblock %}

{% block dashboard_content %}
    {# --- Header : Style Catalogue (Sans cube noir, avec barre de séparation) --- #}
    <div class="page-header" style="display: flex; justify-content: space-between; align-items: center; padding-bottom: 1rem; border-bottom: 1px solid #ccc; margin-bottom: 2rem; margin-top: 1rem;">
        <div>
            <h1 style="margin: 0; font-size: 1.8rem; font-weight: 700;">Tableau de bord</h1>
            <p class="text-muted" style="margin: 0.25rem 0 0 0;">Bienvenue sur votre espace de gestion centralisé.</p>
        </div>
    </div>

    {# --- Corps de la page : Simple & Pro --- #}
    <div class="notice notice-info">
        <div class="notice-icon">👋</div>
        <p>
            Bonjour <strong>{{ user.first_name|default('Utilisateur') }}</strong> ! 
            Vous êtes connecté avec le rôle <strong>{{ user.role|upper }}</strong>. 
        </p>
    </div>
{% endblock %}