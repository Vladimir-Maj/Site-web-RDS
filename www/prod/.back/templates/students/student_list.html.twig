{% extends "dashboard/layout.html.twig" %}

{% block title %}Gestion des Étudiants — StageFlow{% endblock %}

{% block dashboard_content %}
    <div class="page-header">
        <div>
            <h1>Annuaire des Étudiants</h1>
            <p>Gérez les profils et les inscriptions aux promotions.</p>
        </div>
        <div>
            <a href="/dashboard/etudiants/new" class="btn btn-primary">+ Nouvel étudiant</a>
        </div>
    </div>

    <form method="GET" action="/dashboard/etudiants" class="search-bar">
        <div class="form-group">
            <label>Recherche</label>
            <input type="text" name="name" placeholder="Nom, email..." value="{{ filters.name|default('') }}">
        </div>
        <div class="form-group">
            <label>Statut recherche</label>
            <select name="status">
                <option value="">Tous les statuts</option>
                <option value="Searching" {{ filters.status == 'Searching' ? 'selected' : '' }}>🔍 En recherche</option>
                <option value="Hired" {{ filters.status == 'Hired' ? 'selected' : '' }}>✅ En poste</option>
            </select>
        </div>
        <button type="submit" class="btn btn-primary">🔍 Filtrer</button>
    </form>

    <div class="card p-0 overflow-hidden" style="margin-top: 1rem;">
        <table class="table">
            <thead>
                <tr>
                    <th>Étudiant</th>
                    <th>Promotion</th>
                    <th>Statut</th>
                    <th class="text-right">Actions</th>
                </tr>
            </thead>
<tbody>
                {% for s in students %}
                    <tr>
                        <td>
                            <strong>{{ s.first_name }} {{ s.last_name|upper }}</strong><br>
                            {# Correction ici : on utilise .asString() comme pour les pilotes #}
                            <span class="text-xs text-muted">{{ s.email }}</span>
                        </td>
                        <td>
                            {# Correction ici : on utilise la propriété injectée #}
                            <span class="text-sm">{{ s.promo_label|default('N/A') }}</span>
                        </td>
                        <td>
                            <span class="badge {{ s.status == 'Searching' ? 'badge-warning' : 'badge-success' }}">
                                {{ s.status == 'Searching' ? '🔍 En recherche' : '✅ En poste' }}
                            </span>
                        </td>
                        <td class="text-right">
                            <a href="/dashboard/etudiants/{{ s.id }}" class="btn btn-ghost btn-sm">Gérer</a>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="4" class="text-center p-4 text-muted">
                            Aucun étudiant trouvé dans la base.
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
{% endblock %}