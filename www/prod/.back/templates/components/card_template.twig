<div class="card offer-card" style="padding: 1.25rem;">
    <div class="card-header" style="border-bottom: none; padding: 0; margin-bottom: 1rem;">
        <div>
            <h3 style="font-size: 1.1rem; margin-bottom: 0.25rem;">{{ offer.getDisplayTitle() }}</h3>
            <div class="card-meta" style="flex-direction: row; gap: 1rem;">
                <span style="font-size: 0.85rem;">{{ offer.company_name }}</span>
                <span style="font-size: 0.85rem;">•</span>
                <span style="font-size: 0.85rem;">{{ offer.location }}</span>
            </div>
        </div>
        <span class="tag {{ offer.state|lower }}" style="font-size: 0.7rem;">{{ offer.state }}</span>
    </div>
    
    <div class="card-body" style="padding: 0; display: block;">
        <p style="font-size: 0.9rem; color: var(--clr-text-muted); margin-bottom: 1.25rem; line-height: 1.5;">
            {{ offer.description|length > 130 ? offer.description|slice(0, 130) ~ '...' : offer.description }}
        </p>
        
        <div style="display: flex; justify-content: flex-end; gap: 0.75rem; border-top: 1px solid var(--clr-bg); padding-top: 1rem;">
            <a href="/offers/{{ offer.id }}" class="btn btn-primary" style="font-size: 0.75rem;">Voir l'offre</a>
            <a href="/offers/publish" class="btn btn-outline" style="font-size: 0.75rem;">Modifier</a>
        </div>
    </div>
</div>