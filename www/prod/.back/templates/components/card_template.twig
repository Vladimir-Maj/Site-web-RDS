{# .back/templates/components/card_template.twig #}
<div class="card offer-card">
    <div class="card-header">
        <div>
            <h3>{{ offer.getDisplayTitle() }}</h3>
            <div class="card-meta">
                <span><i class="icon">Localisation :</i> {{ offer.location|default('N/C') }}</span>
                <span><i class="icon">Entreprise :</i> {{ offer.company_name|default('Inconnue') }}</span>
                <span><i class="icon">Publié le :</i> {{ offer.created_at|date("d/m/Y") }}</span>
            </div>
        </div>
        {# We use the state for both the class and the text #}
        <span class="tag {{ offer.state|lower }}">{{ offer.state|upper }}</span>
    </div>
    <div class="card-body">
        {# Using slice to keep the card description short #}
        <p>{{ offer.description|length > 150 ? offer.description|slice(0, 150) ~ '...' : offer.description }}</p>
        
        <div class="card-actions">
            {# Generate URLs using the ID #}
            <a href="offers/offer_detail.php?id={{ offer.id }}" class="btn btn-primary">Détails</a>
            <a href="offers/offer_editor.php?id={{ offer.id }}" class="btn btn-outline">Modifier</a>
            <a href="offers/offer_delete.php?id={{ offer.id }}" 
               class="btn btn-danger" 
               onclick="return confirm('CONFIRMER LA SUPPRESSION ?');">
                Supprimer
            </a>
        </div>
    </div>
</div>