{# .back/views/components/card_template.twig #}
<div class="card offer-card">
    <div class="card-header offer-card-header">
        <div class="offer-card-main">
            <h3 class="mb-1 offer-card-title">{{ offer.title }}</h3>

            <div class="card-meta">
    <span>
        <span class="meta-icon" aria-hidden="true">&#127970;</span>
        {{ offer.company_name|default('Entreprise inconnue') }}
    </span>
                <span>
        <span class="meta-icon" aria-hidden="true">&#128205;</span>
        {{ offer.location|default('Non localis�') }}
    </span>
            </div>
        </div>

        <span class="tag {{ offer.is_active ? 'tag-green' : 'tag-slate' }}">
            {{ offer.is_active ? 'OUVERT' : 'ARCHIV�' }}
        </span>
    </div>

    <div class="card-body offer-card-body">
        <p class="offer-card-description">
            {{ offer.description|length > 130 ? offer.description|slice(0, 130) ~ '...' : offer.description }}
        </p>

        <div class="card-actions offer-card-actions">
            <a href="/app/offers/show/{{ offer.id }}{% if from is defined %}?from={{ from }}{% endif %}" class="btn btn-primary">
                Voir l'offre
            </a>

            {% if isPrivileged %}
                <a href="/app/offers/edit/{{ offer.id }}" class="btn btn-outline">
                    Modifier
                </a>
                <form action="/app/offers/delete/{{ offer.id }}" method="POST" onsubmit="return confirm('Supprimer cette offre ?');">
                    <button type="submit" class="btn btn-danger">
                        Supprimer
                    </button>
                </form>
            {% endif %}
        </div>
    </div>
</div>
